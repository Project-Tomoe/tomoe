{
  "name": "@tomoe/bun",
  "version": "0.1.0",
  "description": "Bun adapter for Tomoe",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --watch",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "tomoe": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.1.10",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "tomoe",
    "bun",
    "adapter",
    "http",
    "server"
  ],
  "license": "MIT"
}
